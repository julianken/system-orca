#!/usr/bin/env node
'use strict';

const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');
const http = require('node:http');
const crypto = require('node:crypto');
const { spawn } = require('node:child_process');
const { parseArgs } = require('node:util');

const NAME = 'system-orca';
const PORT = Number(process.env.SYSTEM_ORCA_PORT) || 8765;
const HOST = '127.0.0.1';
const HOME = process.env.SYSTEM_ORCA_HOME || path.join(os.homedir(), '.claude', 'system-orca');
const PID_FILE = path.join(HOME, 'server.pid');
const LOG_FILE = path.join(HOME, 'server.log');
const SERVER_PATH = path.join(__dirname, '..', 'server', 'server.js');
const URL_BASE = `http://${HOST}:${PORT}`;

const SUBCOMMANDS = ['up', 'down', 'status', 'init', 'event', 'plan', 'list', 'archive', 'tail'];

function usage() {
  return [
    `usage: ${NAME} <subcommand> [args]`,
    '',
    'subcommands:',
    '  up                                start the local dashboard server (idempotent)',
    '  down                              stop the local dashboard server (idempotent)',
    '  status                            print server liveness + workflow counts',
    '  init    --title T --goal G [--id] create a workflow; prints id then URL',
    '  event   --workflow ID --type T [--stage-id S] [--data JSON|@file]',
    '  plan    --workflow ID --file P    POST plan_declared from a JSON file',
    '  list    [--all]                   list workflows (table)',
    '  archive <id>                      archive a workflow',
    '  tail    <id>                      stream events.jsonl (^C to exit)',
    '',
    `runtime root: ${HOME}`,
    `server URL:   ${URL_BASE}`,
    '',
  ].join('\n');
}

function readPid() {
  try {
    const raw = fs.readFileSync(PID_FILE, 'utf8').trim();
    const pid = Number(raw);
    return Number.isInteger(pid) && pid > 0 ? pid : null;
  } catch {
    return null;
  }
}

function isAlive(pid) {
  try {
    process.kill(pid, 0);
    return true;
  } catch (err) {
    if (err.code === 'EPERM') return true;
    return false;
  }
}

function unlinkPidFile() {
  try { fs.unlinkSync(PID_FILE); } catch { /* already gone */ }
}

function getJson(pathname, timeoutMs) {
  return new Promise((resolve) => {
    const req = http.request({ host: HOST, port: PORT, path: pathname, method: 'GET' }, (res) => {
      const chunks = [];
      res.on('data', (c) => chunks.push(c));
      res.on('end', () => {
        const body = Buffer.concat(chunks).toString('utf8');
        let json = null;
        try { json = JSON.parse(body); } catch { /* leave null */ }
        resolve({ status: res.statusCode, body, json });
      });
    });
    req.on('error', () => resolve(null));
    if (timeoutMs) req.setTimeout(timeoutMs, () => req.destroy());
    req.end();
  });
}

function postJson(pathname, payload, timeoutMs) {
  return new Promise((resolve) => {
    const buf = Buffer.from(JSON.stringify(payload));
    const req = http.request({
      host: HOST, port: PORT, path: pathname, method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Content-Length': buf.length },
    }, (res) => {
      const chunks = [];
      res.on('data', (c) => chunks.push(c));
      res.on('end', () => {
        const body = Buffer.concat(chunks).toString('utf8');
        let json = null;
        try { json = JSON.parse(body); } catch { /* leave null */ }
        resolve({ status: res.statusCode, body, json });
      });
    });
    req.on('error', () => resolve(null));
    if (timeoutMs) req.setTimeout(timeoutMs, () => req.destroy());
    req.write(buf);
    req.end();
  });
}

async function probeIdentity() {
  const r = await getJson('/api/version', 1000);
  if (r && r.status === 200 && r.json && r.json.name === NAME) return { ours: true, response: r };
  return { ours: false, response: r };
}

function spawnDetached() {
  fs.mkdirSync(HOME, { recursive: true });
  const logFd = fs.openSync(LOG_FILE, 'a');
  const child = spawn(process.execPath, [SERVER_PATH], {
    detached: true,
    stdio: ['ignore', logFd, logFd],
    env: process.env,
  });
  child.unref();
  return child.pid;
}

async function pollUntilOurs(deadlineMs) {
  while (Date.now() < deadlineMs) {
    const probe = await probeIdentity();
    if (probe.ours) return true;
    await new Promise((r) => setTimeout(r, 100));
  }
  return false;
}

function tailLog(maxBytes) {
  try {
    const stat = fs.statSync(LOG_FILE);
    const start = Math.max(0, stat.size - maxBytes);
    const fd = fs.openSync(LOG_FILE, 'r');
    const len = stat.size - start;
    const buf = Buffer.alloc(len);
    fs.readSync(fd, buf, 0, len, start);
    fs.closeSync(fd);
    return buf.toString('utf8');
  } catch {
    return '(no log)';
  }
}

async function up() {
  const existingPid = readPid();
  if (existingPid && isAlive(existingPid)) {
    const probe = await probeIdentity();
    if (probe.ours) {
      process.stdout.write(`server already up at ${URL_BASE}\n`);
      tryLinkToLocalBin();
      return 0;
    }
    const r = probe.response;
    const detail = r
      ? `GET /api/version returned ${r.status}: ${(r.body || '').slice(0, 200)}`
      : 'GET /api/version produced no response';
    process.stderr.write(
      `error: port ${PORT} is held by PID ${existingPid}, but it doesn't appear to be ${NAME} (${detail}).\n` +
      `Free the port (kill ${existingPid}) or set SYSTEM_ORCA_PORT to a different value, then retry.\n`
    );
    return 1;
  }
  if (existingPid) unlinkPidFile();

  spawnDetached();
  const ok = await pollUntilOurs(Date.now() + 5000);
  if (!ok) {
    process.stderr.write(`error: server failed to come up within 5s. Tail of ${LOG_FILE}:\n${tailLog(2048)}\n`);
    return 1;
  }
  process.stdout.write(`server up at ${URL_BASE}\n`);
  tryLinkToLocalBin();
  return 0;
}

function tryLinkToLocalBin() {
  const target = path.resolve(__filename);
  const linkDir = path.join(os.homedir(), '.local', 'bin');
  const linkPath = path.join(linkDir, 'system-orca');
  let dirOnPath = false;
  try {
    dirOnPath = (process.env.PATH || '').split(':').some((p) => {
      try { return fs.realpathSync(p) === fs.realpathSync(linkDir); }
      catch { return p === linkDir; }
    });
  } catch { /* fall through */ }

  let linkDirExists = false;
  try { linkDirExists = fs.statSync(linkDir).isDirectory(); }
  catch { linkDirExists = false; }

  if (!linkDirExists) {
    if (!process.env.SYSTEM_ORCA_QUIET) {
      process.stderr.write(`note: ${linkDir} not found — add the absolute path to PATH or alias:\n  alias system-orca='${target}'\n`);
    }
    return;
  }
  try {
    const existing = fs.readlinkSync(linkPath);
    if (existing === target) return;
  } catch (err) {
    if (err.code !== 'ENOENT') {
      process.stderr.write(`note: ${linkPath} is not a symlink we control; skipping link step\n`);
      return;
    }
  }
  try {
    try { fs.unlinkSync(linkPath); } catch { /* not present */ }
    fs.symlinkSync(target, linkPath);
    if (!dirOnPath) {
      process.stderr.write(`note: linked ${linkPath} → ${target}, but ${linkDir} is not on PATH; add it to PATH to use the bare name 'system-orca'.\n`);
    } else {
      process.stdout.write(`linked ${linkPath} → ${path.basename(target)}\n`);
    }
  } catch { /* permission denied or readonly fs — non-fatal */ }
}

async function down() {
  const pid = readPid();
  if (!pid) {
    process.stdout.write('server is down\n');
    unlinkPidFile();
    return 0;
  }
  if (!isAlive(pid)) {
    unlinkPidFile();
    process.stdout.write('server is down (stale pidfile cleaned)\n');
    return 0;
  }
  try { process.kill(pid, 'SIGTERM'); } catch { /* race: died between checks */ }
  const deadline = Date.now() + 3000;
  while (Date.now() < deadline) {
    if (!isAlive(pid)) break;
    await new Promise((r) => setTimeout(r, 50));
  }
  unlinkPidFile();
  process.stdout.write('server down\n');
  return 0;
}

async function gatherStatus() {
  const pid = readPid();
  const alive = pid && isAlive(pid);
  if (!alive) return { up: false, pid: null, url: URL_BASE };
  const probe = await probeIdentity();
  if (!probe.ours) return { up: false, pid, url: URL_BASE, foreign: true };
  const wf = await getJson('/api/workflows?include_archived=true', 1000);
  const all = (wf && Array.isArray(wf.json)) ? wf.json : [];
  const counts = {
    running:   all.filter((w) => !w.archived && w.status === 'running').length,
    completed: all.filter((w) => !w.archived && w.status === 'completed').length,
    archived:  all.filter((w) => w.archived).length,
  };
  return { up: true, pid, url: URL_BASE, counts };
}

// Renders the `status` subcommand output. The exit code is the boolean
// "is the server up", which the caller maps to 0/1.
//
// TODO(@you, learning-mode): pick a format. Options to consider:
//   1) plain key/value lines (terse, scriptable)
//   2) aligned table (nice when scanning multiple workflows later)
//   3) JSON when --json is passed, otherwise (1)
// state is the object returned by gatherStatus():
//   { up:true,  pid, url, counts:{running, completed, archived} }
//   { up:false, pid:null, url }
//   { up:false, pid, url, foreign:true }   // port held by something else
// 5–10 lines that write to process.stdout. No return value needed.
function formatStatus(state) {
  if (state.foreign) {
    process.stdout.write(`down (port ${PORT} held by foreign PID ${state.pid})\n`);
    process.stdout.write(`url:  ${state.url}\n`);
    return;
  }
  if (!state.up) {
    process.stdout.write('down\n');
    process.stdout.write(`url:  ${state.url}\n`);
    return;
  }
  const c = state.counts;
  process.stdout.write('up\n');
  process.stdout.write(`url:  ${state.url}\n`);
  process.stdout.write(`pid:  ${state.pid}\n`);
  process.stdout.write(`running:   ${c.running}\n`);
  process.stdout.write(`completed: ${c.completed}\n`);
  process.stdout.write(`archived:  ${c.archived}\n`);
}

async function status() {
  const state = await gatherStatus();
  formatStatus(state);
  return state.up ? 0 : 0;
}

function notImplemented(name) {
  process.stderr.write(`${NAME} ${name}: not yet implemented (lands in a later phase)\n`);
  return 2;
}

function pad(s, n) {
  s = String(s == null ? '' : s);
  return s.length >= n ? s : s + ' '.repeat(n - s.length);
}

async function list(rest) {
  let parsed;
  try {
    parsed = parseArgs({
      args: rest,
      options: { all: { type: 'boolean', default: false } },
      allowPositionals: false,
    });
  } catch (err) {
    process.stderr.write(`error: ${err.message}\n`);
    return 1;
  }
  const url = parsed.values.all ? '/api/workflows?include_archived=true' : '/api/workflows';
  const r = await getJson(url, 2000);
  if (!r || r.status !== 200 || !Array.isArray(r.json)) {
    process.stderr.write(`error: list failed — ${describePostFailure(r || {})}\n`);
    return 1;
  }
  const rows = r.json;
  if (!rows.length) {
    process.stdout.write(parsed.values.all ? 'no workflows\n' : 'no active workflows (try --all)\n');
    return 0;
  }
  const idW = Math.max(2, ...rows.map((w) => (w.id || '').length));
  const statusW = Math.max(6, ...rows.map((w) => (w.archived ? 'archived' : (w.status || '')).length));
  const titleW = Math.min(40, Math.max(5, ...rows.map((w) => (w.title || '').length)));
  process.stdout.write(`${pad('ID', idW)}  ${pad('STATUS', statusW)}  ${pad('TITLE', titleW)}  LAST UPDATE\n`);
  for (const w of rows) {
    const status = w.archived ? 'archived' : (w.status || '');
    const title = (w.title || '').slice(0, titleW);
    process.stdout.write(`${pad(w.id, idW)}  ${pad(status, statusW)}  ${pad(title, titleW)}  ${w.last_event_at || ''}\n`);
  }
  return 0;
}

async function archive(rest) {
  if (!rest.length || rest[0].startsWith('-')) {
    process.stderr.write('error: archive requires a workflow id\n  usage: system-orca archive <id>\n');
    return 1;
  }
  const id = rest[0];
  const r = await postJson(`/api/workflows/${encodeURIComponent(id)}/archive`, {}, 5000);
  if (!r || r.status !== 200) {
    process.stderr.write(`error: archive failed — ${describePostFailure(r)}\n`);
    return 1;
  }
  process.stdout.write(`archived ${id}\n`);
  return 0;
}

function formatEventLine(event) {
  const ts = event.ts ? new Date(event.ts).toISOString().slice(11, 19) : '--:--:--';
  const agent = event.agent || '?';
  const stage = event.stage_id ? ` stage=${event.stage_id}` : '';
  const d = event.data || {};
  const text = typeof d.summary === 'string' ? d.summary
             : typeof d.text === 'string'    ? d.text
             : '';
  const tail = text ? ` ${text}` : '';
  return `[${ts}] [${agent}] [${event.type}]${stage}${tail}`;
}

async function tail(rest) {
  if (!rest.length || rest[0].startsWith('-')) {
    process.stderr.write('error: tail requires a workflow id\n  usage: system-orca tail <id>\n');
    return 1;
  }
  const id = rest[0];
  const file = path.join(HOME, 'workflows', id, 'events.jsonl');
  let buffered = '';
  let position = 0;
  try {
    const stat = fs.statSync(file);
    const fd = fs.openSync(file, 'r');
    const buf = Buffer.alloc(stat.size);
    fs.readSync(fd, buf, 0, stat.size, 0);
    fs.closeSync(fd);
    position = stat.size;
    const text = buf.toString('utf8');
    for (const line of text.split('\n')) {
      if (!line) continue;
      try { process.stdout.write(formatEventLine(JSON.parse(line)) + '\n'); }
      catch { process.stdout.write(`(unparseable) ${line}\n`); }
    }
  } catch (err) {
    if (err.code !== 'ENOENT') {
      process.stderr.write(`error: ${err.message}\n`);
      return 1;
    }
    process.stderr.write(`(no events.jsonl yet at ${file}; waiting for new events…)\n`);
  }

  return new Promise((resolve) => {
    const drain = () => {
      try {
        const stat = fs.statSync(file);
        if (stat.size <= position) return;
        const fd = fs.openSync(file, 'r');
        const len = stat.size - position;
        const buf = Buffer.alloc(len);
        fs.readSync(fd, buf, 0, len, position);
        fs.closeSync(fd);
        position = stat.size;
        buffered += buf.toString('utf8');
        let nl;
        while ((nl = buffered.indexOf('\n')) !== -1) {
          const line = buffered.slice(0, nl);
          buffered = buffered.slice(nl + 1);
          if (!line) continue;
          try { process.stdout.write(formatEventLine(JSON.parse(line)) + '\n'); }
          catch { process.stdout.write(`(unparseable) ${line}\n`); }
        }
      } catch (err) {
        if (err.code !== 'ENOENT') process.stderr.write(`tail: ${err.message}\n`);
      }
    };
    let watcher = null;
    try { watcher = fs.watch(path.dirname(file), { persistent: true }, drain); }
    catch { /* fall back to polling */ }
    const poll = setInterval(drain, 500);
    const onSignal = () => {
      clearInterval(poll);
      if (watcher) watcher.close();
      process.stdout.write('\n');
      resolve(0);
    };
    process.on('SIGINT', onSignal);
    process.on('SIGTERM', onSignal);
  });
}

async function plan(rest) {
  let parsed;
  try {
    parsed = parseArgs({
      args: rest,
      options: {
        workflow: { type: 'string' },
        file:     { type: 'string' },
      },
      allowPositionals: false,
    });
  } catch (err) {
    process.stderr.write(`error: ${err.message}\n`);
    return 1;
  }
  const { workflow, file } = parsed.values;
  if (!workflow || !file) {
    process.stderr.write('error: --workflow and --file are required\n');
    return 1;
  }
  let payload;
  try { payload = JSON.parse(fs.readFileSync(file, 'utf8')); }
  catch (err) {
    process.stderr.write(`error: cannot read ${file}: ${err.message}\n`);
    return 1;
  }
  if (!payload || typeof payload !== 'object' || !Array.isArray(payload.stages)) {
    process.stderr.write('error: plan file must be JSON object with a "stages" array\n');
    return 1;
  }
  const r = await postJson('/api/events', {
    workflow_id: workflow,
    type: 'plan_declared',
    agent: process.env.SYSTEM_ORCA_AGENT || 'orchestrator',
    data: { stages: payload.stages },
  }, 10000);
  if (!r || r.status !== 200) {
    process.stderr.write(`error: plan failed — ${describePostFailure(r)}\n`);
    return 1;
  }
  process.stdout.write(`plan declared (${payload.stages.length} stages) for ${workflow}\n`);
  return 0;
}

function todayIso() {
  const d = new Date();
  const y = d.getUTCFullYear();
  const m = String(d.getUTCMonth() + 1).padStart(2, '0');
  const day = String(d.getUTCDate()).padStart(2, '0');
  return `${y}-${m}-${day}`;
}

function generateWorkflowId() {
  return `wf_${todayIso()}_${crypto.randomBytes(2).toString('hex')}`;
}

function parseDataArg(value) {
  if (value == null) return undefined;
  if (typeof value !== 'string') return undefined;
  const raw = value.startsWith('@')
    ? fs.readFileSync(value.slice(1), 'utf8')
    : value;
  return JSON.parse(raw);
}

function describePostFailure(r) {
  if (!r) return 'no response (is the server up? try `system-orca up`)';
  const detail = r.json && r.json.error
    ? `${r.json.error.code}: ${r.json.error.message}`
    : (r.body || '').slice(0, 200);
  return `HTTP ${r.status} — ${detail}`;
}

async function init(rest) {
  let parsed;
  try {
    parsed = parseArgs({
      args: rest,
      options: {
        title: { type: 'string' },
        goal:  { type: 'string' },
        id:    { type: 'string' },
      },
      allowPositionals: false,
    });
  } catch (err) {
    process.stderr.write(`error: ${err.message}\n`);
    return 1;
  }
  const { title, goal, id: idOverride } = parsed.values;
  if (!title || !goal) {
    process.stderr.write('error: --title and --goal are required\n');
    return 1;
  }
  const id = idOverride || generateWorkflowId();
  const r = await postJson('/api/events', {
    workflow_id: id,
    type: 'workflow_init',
    agent: process.env.SYSTEM_ORCA_AGENT || 'orchestrator',
    data: { title, goal },
  }, 5000);
  if (!r || r.status !== 200) {
    process.stderr.write(`error: workflow_init failed — ${describePostFailure(r)}\n`);
    return 1;
  }
  process.stdout.write(`${id}\n${URL_BASE}/w/${id}\n`);
  return 0;
}

async function event(rest) {
  let parsed;
  try {
    parsed = parseArgs({
      args: rest,
      options: {
        workflow:   { type: 'string' },
        type:       { type: 'string' },
        'stage-id': { type: 'string' },
        data:       { type: 'string' },
      },
      allowPositionals: false,
    });
  } catch (err) {
    process.stderr.write(`error: ${err.message}\n`);
    return 1;
  }
  const v = parsed.values;
  if (!v.workflow || !v.type) {
    process.stderr.write('error: --workflow and --type are required\n');
    return 1;
  }
  let data;
  try { data = parseDataArg(v.data); }
  catch (err) {
    process.stderr.write(`error: --data is not valid JSON: ${err.message}\n`);
    return 1;
  }
  const envelope = {
    workflow_id: v.workflow,
    type: v.type,
    agent: process.env.SYSTEM_ORCA_AGENT || 'orchestrator',
  };
  if (v['stage-id']) envelope.stage_id = v['stage-id'];
  if (data !== undefined) envelope.data = data;
  const r = await postJson('/api/events', envelope, 5000);
  if (!r || r.status !== 200) {
    process.stderr.write(`error: event failed — ${describePostFailure(r)}\n`);
    return 1;
  }
  return 0;
}

async function main() {
  const argv = process.argv.slice(2);
  if (argv.length === 0 || argv[0] === '-h' || argv[0] === '--help') {
    process.stdout.write(usage());
    return 0;
  }

  const sub = argv[0];
  const rest = argv.slice(1);

  if (!SUBCOMMANDS.includes(sub)) {
    process.stderr.write(`error: unknown subcommand '${sub}'\n\n${usage()}`);
    return 1;
  }

  switch (sub) {
    case 'up':     return up();
    case 'down':   return down();
    case 'status': return status();
    case 'init':   return init(rest);
    case 'event':  return event(rest);
    case 'plan':   return plan(rest);
    case 'list':   return list(rest);
    case 'archive':return archive(rest);
    case 'tail':   return tail(rest);
    default:       return notImplemented(sub);
  }
}

main().then((code) => process.exit(code)).catch((err) => {
  process.stderr.write(`fatal: ${err && err.stack || err}\n`);
  process.exit(1);
});
