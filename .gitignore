# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp

# Node (the plugin uses zero deps, but local experimentation may pull some in)
node_modules/
package-lock.json
yarn.lock

# Runtime artefacts (server pidfile, logs, workflow state)
# Real runtime lives at ~/.claude/system-orca/ — not in this repo.
# This guard catches accidental copies.
server.pid
server.log
*.jsonl

# OS
Thumbs.db

# Local-only working material — not for the public repo.
# SPEC.md is the durable contract and IS published; PLAN.md and the
# critic verdicts are internal build-order ephemera kept on disk only.
/docs/*
!/docs/SPEC.md
/prior-art/

# Misc
coverage/
*.bak
.netrc
